#!/usr/bin/env bash
set -euo pipefail

TRIGGER="manual"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --trigger)
      TRIGGER="${2:-manual}"
      shift 2
      ;;
    -h|--help)
      echo "Usage: scripts/codex-review-last-commit [--trigger manual|post-commit]"
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [ "${CODEX_REVIEW_ENABLED:-1}" = "0" ]; then
  exit 0
fi

SHA="$(git rev-parse HEAD)"
"$REPO_ROOT/scripts/codex-review-commit" --sha "$SHA" --trigger "$TRIGGER" --lane codex

if [ "${CODEX_REVIEW_INBOX_ENABLED:-1}" != "0" ]; then
  "$REPO_ROOT/scripts/codex-review-inbox" \
    --mode catch-up \
    --sha "$SHA" \
    --max-opens "${CODEX_REVIEW_INBOX_MAX_OPENS:-1}" \
    --include-failed "${CODEX_REVIEW_INBOX_INCLUDE_FAILED:-1}" || true
fi
