#!/bin/sh

echo "========================================"
echo "PRE-COMMIT: running checks"
echo "========================================"

# Bootstrap PATH for GUI git clients that provide a minimal environment.
if [ -d ".tools/bin" ]; then
  PATH="$(pwd)/.tools/bin:$PATH"
fi
if [ -d ".tools/go/bin" ]; then
  PATH="$(pwd)/.tools/go/bin:$PATH"
fi
if [ -d "/opt/homebrew/bin" ]; then
  PATH="/opt/homebrew/bin:$PATH"
fi
if [ -d "/usr/local/bin" ]; then
  PATH="/usr/local/bin:$PATH"
fi
if [ -d "$HOME/.volta/bin" ]; then
  PATH="$HOME/.volta/bin:$PATH"
fi
if [ -d "$HOME/.asdf/shims" ]; then
  PATH="$HOME/.asdf/shims:$PATH"
fi

# If node is still missing, try nvm-installed versions based on .nvmrc.
if ! command -v node >/dev/null 2>&1 && [ -f ".nvmrc" ] && [ -d "$HOME/.nvm/versions/node" ]; then
  NVM_VERSION=$(tr -d '[:space:]' < .nvmrc)
  NVM_BIN_DIR=$(ls -d "$HOME/.nvm/versions/node/v$NVM_VERSION"*/bin 2>/dev/null | head -n 1)
  if [ -n "$NVM_BIN_DIR" ]; then
    PATH="$NVM_BIN_DIR:$PATH"
  fi
fi

# Check if pnpm is available
if ! command -v pnpm >/dev/null 2>&1; then
  echo "========================================"
  echo "PRE-COMMIT FAILED: pnpm not found"
  echo "FIX: npm install -g pnpm  # or: corepack enable"
  echo "========================================"
  exit 1
fi

# Check if node is available (pnpm depends on it)
if ! command -v node >/dev/null 2>&1; then
  echo "========================================"
  echo "PRE-COMMIT FAILED: node not found in PATH"
  echo "FIX: ensure your node runtime is loaded for git hooks"
  echo "     (for nvm users, load nvm in your shell init file)"
  echo "========================================"
  exit 1
fi

# Check if lint-staged is installed at repo root
if ! pnpm exec lint-staged --version >/dev/null 2>&1; then
  echo "========================================"
  echo "PRE-COMMIT FAILED: lint-staged not installed"
  echo "FIX: pnpm install"
  echo "========================================"
  exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  FILES_TO_CHECK=$(git diff --name-only --diff-filter=ACMR)
  LINT_STAGED_ARGS="--diff=HEAD"
else
  FILES_TO_CHECK="$STAGED_FILES"
  LINT_STAGED_ARGS=""
fi

if [ -z "$FILES_TO_CHECK" ]; then
  echo "No changed files to check."
  exit 0
fi

printf "%s\n" "$FILES_TO_CHECK" | node scripts/check-control-plane-doc-sync.mjs --stdin-files || {
  echo "========================================"
  echo "PRE-COMMIT FAILED: control-plane doc sync"
  echo "FIX: edit docs/tooling-validation.md for current workflow changes"
  echo "     and run pnpm tooling:control-plane:note --staged for dated history notes"
  echo "========================================"
  exit 1
}

pnpm exec lint-staged $LINT_STAGED_ARGS || {
  echo "========================================"
  echo "PRE-COMMIT FAILED: lint-staged"
  echo "FIX: pnpm exec lint-staged $LINT_STAGED_ARGS"
  echo "========================================"
  echo "ERROR: lint-staged failed"
  exit 1
}
