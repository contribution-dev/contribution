#!/usr/bin/env node

import { execFileSync } from "node:child_process";
import path from "node:path";
import { pathToFileURL } from "node:url";
import { collectLiveBacklogArtifacts } from "./lib/codex-review-backlog-artifacts.mjs";
import { prepareCodexReviewCliContext } from "./lib/codex-review-cli-bootstrap.mjs";

function usage() {
  console.log(`Usage: scripts/codex-review-findings-backlog [options]

Show remaining review handoffs grouped into actionable findings, contradictory
reports, where zero-finding artifacts are treated as clear by default unless a
structured incomplete-review status still requires follow-up.

Options:
  --reviews-dir <path>        Override review artifact directory
  --include-historical        Include historical backlog entries in the default output
  --json                      Emit machine-readable JSON
  -h, --help                  Show help
`);
}

export function parseArgs(argv) {
  const args = {
    reviewsDir: "",
    includeHistorical: false,
    json: false,
  };

  for (let index = 2; index < argv.length; index += 1) {
    const arg = argv[index];
    const next = argv[index + 1];
    switch (arg) {
      case "--reviews-dir":
        args.reviewsDir = String(next ?? "").trim();
        index += 1;
        break;
      case "--include-historical":
        args.includeHistorical = true;
        break;
      case "--json":
        args.json = true;
        break;
      case "-h":
      case "--help":
        usage();
        process.exit(0);
        break;
      default:
        throw new Error(`Unknown argument: ${arg}`);
    }
  }

  return args;
}

function formatEntry(entry) {
  return `${entry.sha} findings=${entry.findingsCount} severity=${entry.highestSeverityLabel || "unknown"} confidence=${entry.highestConfidence.toFixed(2)} ${entry.summary || "no-summary"}`;
}

function currentHeadSha(repoRoot) {
  try {
    return execFileSync("git", ["rev-parse", "HEAD"], {
      cwd: repoRoot,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    })
      .trim()
      .toLowerCase();
  } catch {
    return "";
  }
}

async function main() {
  const args = parseArgs(process.argv);
  const invocationCwd = process.env.CODEX_REVIEW_CALLER_CWD || process.cwd();
  const { repoRoot, reviewsDir } = await prepareCodexReviewCliContext({
    invocationCwd,
    reviewsDirOverride: args.reviewsDir,
    warnPrefix: "codex-review-findings-backlog",
  });
  const artifacts = await collectLiveBacklogArtifacts(reviewsDir, {
    headSha: currentHeadSha(repoRoot),
  });

  const adjudication = artifacts.filter((entry) => entry.requiresAdjudication);
  const actionable = artifacts.filter(
    (entry) => entry.category === "actionable" && !entry.requiresAdjudication,
  );
  const currentTipActionable = actionable.filter(
    (entry) => entry.scope === "head" && entry.ownership !== "remediation",
  );
  const historicalActionable = actionable.filter(
    (entry) => entry.scope !== "head" && entry.ownership !== "remediation",
  );
  const remediationOwned = actionable.filter(
    (entry) => entry.ownership === "remediation",
  );
  const visibleActionable = args.includeHistorical
    ? [...currentTipActionable, ...historicalActionable]
    : currentTipActionable;
  const contradictory = artifacts.filter(
    (entry) => entry.category === "contradictory",
  );
  if (args.json) {
    console.log(
      JSON.stringify(
        {
          actionable: visibleActionable,
          current_tip_actionable: currentTipActionable,
          historical_actionable: args.includeHistorical
            ? historicalActionable
            : [],
          historical_actionable_hidden_count: args.includeHistorical
            ? 0
            : historicalActionable.length,
          remediation_owned_actionable: remediationOwned,
          remediation_owned_actionable_count: remediationOwned.length,
          needs_adjudication: adjudication,
          needs_adjudication_count: adjudication.length,
          contradictory,
        },
        null,
        2,
      ),
    );
    return;
  }

  console.log("[current-tip actionable]");
  console.log(`count=${currentTipActionable.length}`);
  for (const entry of currentTipActionable) {
    console.log(formatEntry(entry));
  }

  if (args.includeHistorical) {
    console.log("\n[historical backlog]");
    console.log(`count=${historicalActionable.length}`);
    for (const entry of historicalActionable) {
      console.log(formatEntry(entry));
    }
  } else if (historicalActionable.length > 0) {
    console.log("\n[historical backlog]");
    console.log(
      `hidden=${historicalActionable.length} rerun with --include-historical to inspect`,
    );
  }

  console.log("\n[owned by remediation]");
  console.log(`count=${remediationOwned.length}`);
  if (args.includeHistorical) {
    for (const entry of remediationOwned) {
      console.log(formatEntry(entry));
    }
  }

  console.log("\n[needs adjudication]");
  console.log(`count=${adjudication.length}`);
  if (args.includeHistorical) {
    for (const entry of adjudication) {
      console.log(formatEntry(entry));
    }
  }

  console.log("\n[contradictory]");
  console.log(`count=${contradictory.length}`);
  if (args.includeHistorical) {
    for (const entry of contradictory) {
      console.log(formatEntry(entry));
    }
  }
}

if (
  import.meta.url === pathToFileURL(path.resolve(process.argv[1] ?? "")).href
) {
  main().catch((error) => {
    console.error(`[codex-review-findings-backlog] Failed: ${error.message}`);
    process.exit(1);
  });
}
