#!/usr/bin/env node

import { spawnSync } from "node:child_process";
import { rm, readdir, stat } from "node:fs/promises";
import path from "node:path";
import { pathToFileURL } from "node:url";
import { resolveReviewsDir } from "./codex-review-inbox-lib.mjs";
import { isReviewProcessRunningForSha } from "./codex-review-push-gate-lib.mjs";

const DEFAULT_STALE_MS = 10 * 60 * 1000;

const IN_PROGRESS_PATTERNS = [
  /\.patch\./,
  /\.prompt\./,
  /\.tmp-json\./,
  /\.tmp-json-lm\./,
  /\.tmp-md\./,
  /\.tmp-status-/,
  /\.tmp-reason-/,
  /\.tmp-attempts-/,
  /\.tmp\./,
];

function usage() {
  const defaultSeconds = Math.floor(DEFAULT_STALE_MS / 1000);
  console.log(`Usage: scripts/codex-review-clean-stale [options]

Options:
  --reviews-dir <path>        Override reviews directory
  --stale-seconds <n>         Delete temp artifacts older than n seconds (default: ${defaultSeconds})
  --dry-run                   Show what would be deleted without removing files
  -h, --help                  Show this help
`);
}

function parseArgs(argv) {
  const args = {
    reviewsDir:
      process.env.CODE_REVIEW_DIR && process.env.CODE_REVIEW_DIR.trim()
        ? process.env.CODE_REVIEW_DIR.trim()
        : "",
    staleMs: resolveStaleMs(),
    dryRun: false,
  };

  for (let i = 2; i < argv.length; i += 1) {
    const arg = argv[i];
    const next = argv[i + 1];
    switch (arg) {
      case "--reviews-dir":
        args.reviewsDir = String(next ?? "");
        i += 1;
        break;
      case "--stale-seconds": {
        const parsed = Number.parseInt(String(next ?? ""), 10);
        if (!Number.isInteger(parsed) || parsed < 0) {
          throw new Error(`Invalid --stale-seconds: ${next}`);
        }
        args.staleMs = parsed * 1000;
        i += 1;
        break;
      }
      case "--dry-run":
        args.dryRun = true;
        break;
      case "-h":
      case "--help":
        usage();
        process.exit(0);
        break;
      default:
        throw new Error(`Unknown argument: ${arg}`);
    }
  }

  return args;
}

function parseNonNegativeInt(value) {
  const parsed = Number.parseInt(String(value ?? ""), 10);
  if (!Number.isFinite(parsed) || parsed < 0) return null;
  return parsed;
}

function resolveStaleMs() {
  const fromEnv = parseNonNegativeInt(
    process.env.CODEX_REVIEW_IN_PROGRESS_STALE_SECONDS,
  );
  if (fromEnv !== null) {
    return fromEnv * 1000;
  }
  return DEFAULT_STALE_MS;
}

function extractSha(name) {
  const match = /^([0-9a-f]{40})\./i.exec(name);
  return match ? match[1] : "";
}

function isTempInProgressArtifact(name) {
  return IN_PROGRESS_PATTERNS.some((pattern) => pattern.test(name));
}

function snapshotProcessTable() {
  const attempts = [
    ["-axww", "-o", "pid=,command="],
    ["-axo", "pid=,command="],
  ];
  for (const args of attempts) {
    const ps = spawnSync("ps", args, {
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    });
    if (ps.status !== 0) continue;
    return String(ps.stdout ?? "");
  }
  return "";
}

async function main() {
  const args = parseArgs(process.argv);
  const repoRoot = process.env.REPO_ROOT || process.cwd();
  const reviewsDir = await resolveReviewsDir(repoRoot, args.reviewsDir);

  const processListText = snapshotProcessTable();

  const nowMs = Date.now();
  const scanDirs = [reviewsDir];
  const removable = [];

  for (const scanDir of scanDirs) {
    const fileNames = await readdir(scanDir).catch(() => []);

    for (const name of fileNames) {
      if (!isTempInProgressArtifact(name)) continue;
      const sha = extractSha(name);
      if (!sha) continue;
      if (isReviewProcessRunningForSha(sha, processListText)) continue;

      const fullPath = path.join(scanDir, name);
      const info = await stat(fullPath).catch(() => null);
      if (!info || !Number.isFinite(info.mtimeMs)) continue;
      if (nowMs - info.mtimeMs < args.staleMs) continue;

      removable.push(fullPath);
    }
  }

  if (removable.length === 0) {
    console.log(
      "[codex-review-clean-stale] no stale review temp artifacts found",
    );
    return;
  }

  for (const filePath of removable) {
    if (!args.dryRun) {
      await rm(filePath, { force: true });
    }
    console.log(`${args.dryRun ? "would-delete" : "deleted"} ${filePath}`);
  }

  console.log(
    `[codex-review-clean-stale] ${args.dryRun ? "would_remove" : "removed"} temp_artifacts=${removable.length} stale_seconds=${Math.floor(args.staleMs / 1000)}`,
  );
}

if (
  import.meta.url === pathToFileURL(path.resolve(process.argv[1] ?? "")).href
) {
  main().catch((error) => {
    console.error(`[codex-review-clean-stale] Failed: ${error.message}`);
    process.exit(1);
  });
}
